<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:FurudType.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FurudType.App.Views.MainView"
        x:DataType="vm:MainViewModel"
        Title="FurudType"
        Focusable="True">
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="TextInput">
            <InvokeCommandAction Command="{Binding HandleTextInputCommandCommand}"
                                 PassEventArgsToCommand="True"/>
        </EventTriggerBehavior>
    </Interaction.Behaviors>
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Label Grid.Row="0" Content="Here will info about exercise" />
        <Label Grid.Row="1" Content="Here will info about speed" />
        <StackPanel Grid.Row="2" Margin="10">
            <Label Content="{Binding TextToDisplay}" />
        </StackPanel>
        <Label Grid.Row="3" Content="Here will keyboard" />
    </Grid>
</Window>
