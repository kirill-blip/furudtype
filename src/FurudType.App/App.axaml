<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FurudType.App.Converters"
             xmlns:local="clr-namespace:FurudType.App"
             x:Class="FurudType.App.App"
             RequestedThemeVariant="Light">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <conv:IsCorrectToBrushConverter x:Key="IsCorrectToBrushConverter" />
        <conv:CursorVisibilityConverter x:Key="CursorVisibilityConverter" />
        <conv:KeyItemConverter x:Key="KeyItemConverter" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://FurudType.App/Styles/AppDefaultStyles.axaml"></StyleInclude>
    </Application.Styles>
</Application>